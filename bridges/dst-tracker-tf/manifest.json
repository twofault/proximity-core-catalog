{
  "id": "dst-tracker-tf",
  "name": "Don't Starve Together",
  "description": "Extracts player and camera position from Don't Starve Together",
  "version": "1.0.5",
  "author": "twofault",
  "entry": "main.lua",
  "gamelink_script": "dst_tracker.lua",
  "game_engines": [
    "lua_custom"
  ],
  "compatibility": {
    "platforms": [
      "windows"
    ],
    "executable": {
      "any_of": [
        {
          "exact": "dontstarve_steam.exe"
        },
        {
          "exact": "dontstarve_steam_x64.exe"
        }
      ]
    }
  },
  "capabilities": {
    "uses_blockable_apis": true,
    "uses_game_session": false
  },
  "http_endpoints": [],
  "warn_on_unlisted_targets": false,
  "bridge_scope": "game_specific",
  "tags": [
    "dont-starve-together",
    "dst",
    "klei",
    "survival",
    "lua",
    "experimental"
  ]
}
