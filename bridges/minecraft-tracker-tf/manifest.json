{
  "id": "minecraft-tracker-tf",
  "name": "Minecraft Java Edition",
  "description": "Extracts player position from Minecraft Java Edition using GameLink with automatic deobfuscation",
  "version": "1.0.6",
  "author": "twofault",
  "entry": "main.lua",
  "gamelink_script": "minecraft_tracker.lua",
  "game_engines": [
    "java"
  ],
  "compatibility": {
    "platforms": [
      "windows"
    ],
    "executable": {
      "any_of": [
        {
          "exact": "javaw.exe"
        },
        {
          "exact": "java.exe"
        }
      ]
    },
    "window_title": {
      "any_of": [
        {
          "starts_with": "Minecraft"
        }
      ],
      "none_of": [
        {
          "contains": "Launcher"
        }
      ]
    },
    "structure": {
      "ancestor_contains": ".minecraft",
      "ancestor_depth": 6
    }
  },
  "capabilities": {
    "uses_blockable_apis": true,
    "uses_game_session": false
  },
  "http_endpoints": [
    "https://launchermeta.mojang.com/**",
    "https://piston-meta.mojang.com/**",
    "https://piston-data.mojang.com/**"
  ],
  "warn_on_unlisted_targets": false,
  "bridge_scope": "game_specific",
  "tags": [
    "minecraft",
    "java-edition",
    "mojang",
    "java",
    "experimental"
  ]
}
